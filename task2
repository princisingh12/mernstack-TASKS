<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>User Personal Information Form</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family: Georgia, serif;
    }

    body{
        background:#ececec;
        padding:8px;
    }

    .container{
        width:440px;
        background:#f5f5f5;
        padding:18px;
        border-radius:10px;
        box-shadow:0 0 5px rgba(0,0,0,0.15);
    }

    fieldset{
        border:1px solid #000;
        padding:15px 10px 20px;
    }

    legend{
        font-size:16px;
        font-weight:bold;
        padding:0 6px;
    }

    label{
        display:block;
        margin-top:12px;
        margin-bottom:6px;
        font-size:16px;
    }

    input[type="text"],
    input[type="email"],
    input[type="password"],
    input[type="date"],
    textarea{
        width:100%;
        padding:10px;
        border:1px solid #bfbfbf;
        border-radius:4px;
        font-size:16px;
    }

    .radio-group{
        margin-top:8px;
    }

    .radio-group label{
        display:inline;
        margin-right:18px;
        font-size:15px;
    }

    textarea{
        resize:none;
        height:45px;
    }

    .submit-btn{
        margin-top:18px;
        padding:10px 25px;
        font-size:18px;
        border:2px solid #333;
        border-radius:5px;
        background:white;
        cursor:pointer;
    }

    .submit-btn:hover{
        background:#e8e8e8;
    }
</style>
</head>

<body>

<div class="container">

    <fieldset>
        <legend>User personal information</legend>

        <label>Enter your full name</label>
        <input type="text" value="Rahul Kumar">

        <label>Enter your email</label>
        <input type="email" value="geeks@12345gmail.com">

        <label>Enter your password</label>
        <input type="password">

        <label>Confirm your password</label>
        <input type="password">

        <label>Enter your gender</label>

        <div class="radio-group">
            <input type="radio" id="male" name="gender" checked>
            <label for="male">Male</label>

            <input type="radio" id="female" name="gender">
            <label for="female">Female</label>

            <input type="radio" id="others" name="gender">
            <label for="others">Others</label>
        </div>

        <label>Enter your Date of Birth</label>
        <input type="date" value="2009-10-06">

        <label>Enter your Address:</label>
        <textarea>Noida Sector 137</textarea>

        <button type="submit" class="submit-btn">submit</button>

    </fieldset>

</div>

</body>
</html>